<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <Color x:Key="Ds.Color.Background">#F6FAF8</Color>
    <Color x:Key="Ds.Color.Surface">#FFFFFF</Color>
    <Color x:Key="Ds.Color.SurfaceVariant">#E8F0ED</Color>
    <Color x:Key="Ds.Color.SurfaceVariantHover">#D9E6E1</Color>
    <Color x:Key="Ds.Color.SurfaceVariantPressed">#C9DAD4</Color>
    <Color x:Key="Ds.Color.OnSurface">#15201D</Color>
    <Color x:Key="Ds.Color.OnSurfaceMuted">#4B625B</Color>
    <Color x:Key="Ds.Color.Outline">#70817C</Color>
    <Color x:Key="Ds.Color.Primary">#006B5B</Color>
    <Color x:Key="Ds.Color.PrimaryHover">#00574A</Color>
    <Color x:Key="Ds.Color.PrimaryPressed">#00463C</Color>
    <Color x:Key="Ds.Color.OnPrimary">#FFFFFF</Color>
    <Color x:Key="Ds.Color.Connected">#18794E</Color>
    <Color x:Key="Ds.Color.Syncing">#9A6500</Color>
    <Color x:Key="Ds.Color.Offline">#5E6C68</Color>
    <Color x:Key="Ds.Color.Error">#BA1A1A</Color>
    <Color x:Key="Ds.Color.Attention">#8A4F00</Color>

    <SolidColorBrush x:Key="Ds.Brush.Background" Color="{DynamicResource Ds.Color.Background}" />
    <SolidColorBrush x:Key="Ds.Brush.Surface" Color="{DynamicResource Ds.Color.Surface}" />
    <SolidColorBrush x:Key="Ds.Brush.SurfaceVariant" Color="{DynamicResource Ds.Color.SurfaceVariant}" />
    <SolidColorBrush x:Key="Ds.Brush.SurfaceVariantHover" Color="{DynamicResource Ds.Color.SurfaceVariantHover}" />
    <SolidColorBrush x:Key="Ds.Brush.SurfaceVariantPressed" Color="{DynamicResource Ds.Color.SurfaceVariantPressed}" />
    <SolidColorBrush x:Key="Ds.Brush.OnSurface" Color="{DynamicResource Ds.Color.OnSurface}" />
    <SolidColorBrush x:Key="Ds.Brush.OnSurfaceMuted" Color="{DynamicResource Ds.Color.OnSurfaceMuted}" />
    <SolidColorBrush x:Key="Ds.Brush.Outline" Color="{DynamicResource Ds.Color.Outline}" />
    <SolidColorBrush x:Key="Ds.Brush.Primary" Color="{DynamicResource Ds.Color.Primary}" />
    <SolidColorBrush x:Key="Ds.Brush.PrimaryHover" Color="{DynamicResource Ds.Color.PrimaryHover}" />
    <SolidColorBrush x:Key="Ds.Brush.PrimaryPressed" Color="{DynamicResource Ds.Color.PrimaryPressed}" />
    <SolidColorBrush x:Key="Ds.Brush.OnPrimary" Color="{DynamicResource Ds.Color.OnPrimary}" />
    <SolidColorBrush x:Key="Ds.Brush.Connected" Color="{DynamicResource Ds.Color.Connected}" />
    <SolidColorBrush x:Key="Ds.Brush.Syncing" Color="{DynamicResource Ds.Color.Syncing}" />
    <SolidColorBrush x:Key="Ds.Brush.Offline" Color="{DynamicResource Ds.Color.Offline}" />
    <SolidColorBrush x:Key="Ds.Brush.Error" Color="{DynamicResource Ds.Color.Error}" />
    <SolidColorBrush x:Key="Ds.Brush.Attention" Color="{DynamicResource Ds.Color.Attention}" />

    <sys:Double x:Key="Ds.Space.4">4</sys:Double>
    <sys:Double x:Key="Ds.Space.8">8</sys:Double>
    <sys:Double x:Key="Ds.Space.12">12</sys:Double>
    <sys:Double x:Key="Ds.Space.16">16</sys:Double>
    <sys:Double x:Key="Ds.Space.24">24</sys:Double>
    <sys:Double x:Key="Ds.Space.32">32</sys:Double>
    <CornerRadius x:Key="Ds.Radius.Compact">8</CornerRadius>
    <CornerRadius x:Key="Ds.Radius.Control">12</CornerRadius>
    <CornerRadius x:Key="Ds.Radius.Card">16</CornerRadius>
    <sys:Double x:Key="Ds.Type.Body">16</sys:Double>
    <sys:Double x:Key="Ds.Type.BodySmall">14</sys:Double>
    <sys:Double x:Key="Ds.Type.Label">13</sys:Double>
    <sys:Double x:Key="Ds.Type.Title">20</sys:Double>
    <sys:Double x:Key="Ds.Type.TitleLarge">24</sys:Double>
    <DropShadowEffect x:Key="Ds.Elevation.Card" x:Shared="False" BlurRadius="12" ShadowDepth="2" Opacity="0.16" Color="#15201D" />
</ResourceDictionary>
