<Window x:Class="DeviceSync.App.PairingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add phone"
        Width="600"
        Height="760"
        MinWidth="520"
        MinHeight="680"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Add phone" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding PairingState}" Margin="0,6,0,16" Foreground="#555555" TextWrapping="Wrap" />

            <Border Background="White"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    Padding="16"
                    HorizontalAlignment="Center">
                <Image Source="{Binding PairingQrImage}"
                       Width="480"
                       Height="480"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
            </Border>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Windows name" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding PairingDeviceName}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="2" Text="Time remaining" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PairingTimeRemaining}" />
                <TextBlock Grid.Row="4" Text="Verification code" FontWeight="SemiBold" />
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding PairingVerificationCode}"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Row="6" Text="Listening" FontWeight="SemiBold" />
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ListeningEndpoint}" />
                <TextBlock Grid.Row="8" Text="Advertised" FontWeight="SemiBold" />
                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding TcpEndpoint}" />
            </Grid>

            <StackPanel Margin="0,20,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Visibility="{Binding IsPairingConfirmationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Content="Matches" Width="96" Margin="0,0,8,0" Command="{Binding ConfirmPairingCodeCommand}" />
                <Button Content="Does not match" Width="128" Command="{Binding RejectPairingCodeCommand}" />
            </StackPanel>

            <StackPanel Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save QR"
                        Width="88"
                        Margin="0,0,8,0"
                        Command="{Binding SavePairingQrCommand}"
                        Visibility="{Binding IsDebugBuild, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Content="New code" Width="88" Margin="0,0,8,0" Command="{Binding NewPairingCodeCommand}" />
                <Button Content="Cancel" Width="88" Command="{Binding CancelPairingCommand}" Click="Cancel_Click" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
