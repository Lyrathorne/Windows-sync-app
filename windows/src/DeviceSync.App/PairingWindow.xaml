<Window x:Class="DeviceSync.App.PairingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc.Pairing.Title}"
        Width="600"
        Height="760"
        MinWidth="520"
        MinHeight="680"
        SnapsToDevicePixels="True" Style="{StaticResource Ds.Window}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="{DynamicResource Loc.Pairing.Title}" Style="{StaticResource Ds.Text.TitleLarge}" />
            <TextBlock Text="{Binding PairingState}" Margin="0,6,0,16" Style="{StaticResource Ds.Text.Muted}" TextWrapping="Wrap" AutomationProperties.LiveSetting="Polite" />

            <Border Background="White"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    Padding="16"
                    HorizontalAlignment="Center">
                <Image Source="{Binding PairingQrImage}"
                       Width="480"
                       Height="480"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       AutomationProperties.Name="DeviceSync pairing QR code" />
            </Border>

            <TextBox Text="{Binding DebugPairingPayload, Mode=OneWay}"
                     Margin="0,12,0,0"
                     MaxHeight="80"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Visibility="{Binding IsDebugBuild, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource Loc.Pairing.WindowsName}" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding PairingDeviceName}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="2" Text="{DynamicResource Loc.Pairing.TimeRemaining}" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PairingTimeRemaining}" />
                <TextBlock Grid.Row="4" Text="{DynamicResource Loc.Pairing.VerificationCode}" FontWeight="SemiBold" />
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding PairingVerificationCode}"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Row="6" Text="{DynamicResource Loc.Pairing.Listening}" FontWeight="SemiBold" />
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ListeningEndpoint}" />
                <TextBlock Grid.Row="8" Text="{DynamicResource Loc.Pairing.Advertised}" FontWeight="SemiBold" />
                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding TcpEndpoint}" />
            </Grid>

            <StackPanel Margin="0,20,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Visibility="{Binding IsPairingConfirmationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Content="{DynamicResource Loc.Pairing.Matches}" MinWidth="96" MinHeight="48" Margin="0,0,8,0" Command="{Binding ConfirmPairingCodeCommand}" />
                <Button Content="{DynamicResource Loc.Pairing.DoesNotMatch}" MinWidth="128" MinHeight="48" Command="{Binding RejectPairingCodeCommand}" />
            </StackPanel>

            <StackPanel Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Loc.Pairing.SaveQr}"
                        Width="88"
                        Margin="0,0,8,0"
                        Command="{Binding SavePairingQrCommand}"
                        Visibility="{Binding IsDebugBuild, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Content="{DynamicResource Loc.Pairing.NewCode}" MinWidth="88" MinHeight="48" Margin="0,0,8,0" Command="{Binding NewPairingCodeCommand}" />
                <Button Content="{DynamicResource Loc.Cancel}" MinWidth="88" MinHeight="48" Command="{Binding CancelPairingCommand}" Click="Cancel_Click" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
