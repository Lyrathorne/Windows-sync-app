<Window x:Class="DeviceSync.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeviceSync"
        Width="760"
        Height="640"
        MinWidth="640"
        MinHeight="520"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="DeviceSync" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Status}" Margin="0,6,0,0" Foreground="#555555" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Server" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding ServerSummary}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="2" Text="Windows Device ID" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WindowsDeviceId}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="4" Text="Port" FontWeight="SemiBold" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Port}" />
                <TextBlock Grid.Row="6" Text="Listening" FontWeight="SemiBold" />
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ListeningEndpoint}" TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Border Grid.Row="4" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Discovery" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding DiscoverySummary}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="2" Text="Instance name" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DiscoveryInstanceName}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="4" Text="Service type" FontWeight="SemiBold" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DiscoveryServiceType}" />
                <TextBlock Grid.Row="6" Text="Published port" FontWeight="SemiBold" />
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding DiscoveryPublishedPort}" />
                <TextBlock Grid.Row="8" Text="Advertised" FontWeight="SemiBold" />
                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding TcpEndpoint}" />
                <TextBlock Grid.Row="10" Text="Last publish/error" FontWeight="SemiBold" />
                <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding DiscoveryLastPublishedAtUtc}" TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Border Grid.Row="6" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Connected Android Device" FontSize="18" FontWeight="SemiBold" />
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Name" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{Binding ConnectedDeviceName}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2" Text="Device ID" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ConnectedDeviceId}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="4" Text="Connected at" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ConnectedAtUtc}" TextWrapping="Wrap" />
                </Grid>

                <TextBlock Grid.Row="3" Text="Trusted phones" FontSize="16" FontWeight="SemiBold" />
                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding TrustedPhones}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding DeviceId}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Fingerprint}" />
                                            <TextBlock Text="{Binding TrustStatus}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Remove trust"
                                                Command="{Binding DataContext.RevokeTrustedPhoneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding DeviceId}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <DockPanel Grid.Row="7" Margin="0,16,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" Width="260">
                <CheckBox Content="Clipboard sync (opt-in)" IsChecked="{Binding ClipboardSyncEnabled}" />
                <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" />
                <DockPanel Margin="0,6,0,0">
                    <Button DockPanel.Dock="Right" Content="Send" Width="52" Command="{Binding SendTextCommand}" />
                    <TextBox Text="{Binding TextToShare, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0" />
                </DockPanel>
                <Button Content="Send clipboard now" Margin="0,6,0,0" Command="{Binding SendClipboardCommand}" />
                <Button Content="Select folder to compare" Margin="0,6,0,0" Command="{Binding StartFolderSyncCommand}" />
                <TextBlock Text="{Binding FolderSyncStatus}" TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding FolderConflicts}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding RelativePath}" TextTrimming="CharacterEllipsis" />
                                <ComboBox ItemsSource="{Binding Options}" SelectedItem="{Binding Resolution}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="Approve folder plan" Margin="0,6,0,0" Command="{Binding ApproveFolderSyncCommand}" />
                <ItemsControl ItemsSource="{Binding SharedTextHistory}" Margin="0,6,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Text}"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding DataContext.OpenSharedLinkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding Notifications}" Margin="0,6,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" ToolTip="{Binding Text}" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <StackPanel Width="190" Margin="0,0,12,0">
                    <TextBlock Text="{Binding OutgoingFileStatus}" TextTrimming="CharacterEllipsis" />
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding OutgoingFileProgress}" Height="8" />
                </StackPanel>
                <Button Content="Send file" Width="88" Margin="0,0,8,0" Command="{Binding SendFileCommand}" />
                <Button Content="Cancel file" Width="88" Margin="0,0,8,0" Command="{Binding CancelOutgoingFileCommand}" />
                <Button Content="Start"
                        Width="88"
                        Margin="0,0,8,0"
                        Command="{Binding StartCommand}"
                        Visibility="{Binding IsRetryStartVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Content="Stop" Width="88" Margin="0,0,8,0" Command="{Binding StopCommand}" />
                <Button Content="Discovery" Width="88" Margin="0,0,8,0" Command="{Binding RestartDiscoveryCommand}" />
                <Button Content="Add phone" Width="96" Margin="0,0,8,0" Click="AddPhone_Click" />
                <Button Content="Disconnect" Width="104" Command="{Binding DisconnectCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
