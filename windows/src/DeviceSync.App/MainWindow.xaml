<Window x:Class="DeviceSync.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeviceSync" Height="420" Width="640" MinHeight="360" MinWidth="520">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="DeviceSync" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Status}" Margin="0,6,0,0" Foreground="#555555" />
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Server" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding ServerSummary}" />
                <TextBlock Grid.Row="2" Text="Windows Device ID" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WindowsDeviceId}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="4" Text="Port" FontWeight="SemiBold" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Port}" />
            </Grid>
        </Border>

        <Border Grid.Row="4" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Automatic discovery" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding DiscoverySummary}" />
                <TextBlock Grid.Row="2" Text="Instance name" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DiscoveryInstanceName}" />
                <TextBlock Grid.Row="4" Text="Service type" FontWeight="SemiBold" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DiscoveryServiceType}" />
                <TextBlock Grid.Row="6" Text="Published port" FontWeight="SemiBold" />
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding DiscoveryPublishedPort}" />
                <TextBlock Grid.Row="8" Text="Last publish/error" FontWeight="SemiBold" />
                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding DiscoveryLastPublishedAtUtc}" />
            </Grid>
        </Border>

        <Border Grid.Row="6" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Adding phone" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding PairingState}" />
                <Image Grid.Column="2" Grid.RowSpan="9" Source="{Binding PairingQrImage}" Width="160" Height="160" Stretch="Uniform" />
                <TextBlock Grid.Row="2" Text="Windows name" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PairingDeviceName}" />
                <TextBlock Grid.Row="4" Text="Time remaining" FontWeight="SemiBold" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PairingTimeRemaining}" />
                <TextBlock Grid.Row="6" Text="Verification code" FontWeight="SemiBold" />
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PairingVerificationCode}" FontSize="18" FontWeight="SemiBold" />
                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Matches" Width="88" Margin="0,0,8,0" Command="{Binding ConfirmPairingCodeCommand}" />
                    <Button Content="Does not match" Width="120" Command="{Binding RejectPairingCodeCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="8" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Connected Android Device" FontSize="18" FontWeight="SemiBold" />
                <StackPanel Grid.Row="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Name" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{Binding ConnectedDeviceName}" />
                    <TextBlock Grid.Row="2" Text="Device ID" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ConnectedDeviceId}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="4" Text="Capabilities" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ConnectedCapabilities}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="6" Text="Connected at" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ConnectedAtUtc}" />
                </Grid>
                <TextBlock Text="Trusted phones" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,8" />
                <ItemsControl ItemsSource="{Binding TrustedPhones}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DeviceId}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Fingerprint}" />
                                        <TextBlock Text="{Binding PairedAtUtc}" />
                                        <TextBlock Text="{Binding LastVerifiedAtUtc}" />
                                        <TextBlock Text="{Binding TrustStatus}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Remove trust"
                                            Command="{Binding DataContext.RevokeTrustedPhoneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding DeviceId}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Start" Width="88" Margin="0,0,8,0" Command="{Binding StartCommand}" />
            <Button Content="Stop" Width="88" Margin="0,0,8,0" Command="{Binding StopCommand}" />
            <Button Content="Discovery" Width="88" Margin="0,0,8,0" Command="{Binding RestartDiscoveryCommand}" />
            <Button Content="Add phone" Width="96" Margin="0,0,8,0" Command="{Binding AddPhoneCommand}" />
            <Button Content="New code" Width="88" Margin="0,0,8,0" Command="{Binding NewPairingCodeCommand}" />
            <Button Content="Cancel pairing" Width="112" Margin="0,0,8,0" Command="{Binding CancelPairingCommand}" />
            <Button Content="Disconnect" Width="104" Command="{Binding DisconnectCommand}" />
        </StackPanel>
    </Grid>
</Window>
