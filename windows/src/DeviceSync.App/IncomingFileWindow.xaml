<Window x:Class="DeviceSync.App.IncomingFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc.Incoming.Title}"
        Width="560"
        Height="500"
        MinWidth="480"
        MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource Ds.Window}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{DynamicResource Loc.Incoming.Heading}" Style="{StaticResource Ds.Text.TitleLarge}" />
            <TextBlock Text="{DynamicResource Loc.Incoming.Review}" Style="{StaticResource Ds.Text.Muted}" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Loc.Device}" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="{Binding DeviceName}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="2" Text="{DynamicResource Loc.File}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FileName}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="4" Text="{DynamicResource Loc.Size}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FileSize}" />
            <TextBlock Grid.Row="6" Text="{DynamicResource Loc.Mime}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding MimeType}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="8" Text="{DynamicResource Loc.SaveTo}" FontWeight="SemiBold" />
            <DockPanel Grid.Row="8" Grid.Column="1">
                <Button DockPanel.Dock="Right" Content="{DynamicResource Loc.Choose}" MinHeight="48" Margin="8,0,0,0" Command="{Binding ChooseFolderCommand}" />
                <TextBlock Text="{Binding SaveDirectory}" TextWrapping="Wrap" VerticalAlignment="Center" />
            </DockPanel>

            <ProgressBar Grid.Row="10" Grid.ColumnSpan="2" Height="18" Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}" AutomationProperties.Name="File transfer progress" />
            <TextBlock Grid.Row="12" Grid.ColumnSpan="2" Text="{Binding ProgressText}" />
            <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding SpeedText}" HorizontalAlignment="Right" />
            <TextBlock Grid.Row="14" Grid.ColumnSpan="2" Text="{Binding Status}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="16" Grid.ColumnSpan="2" Text="{Binding Error}" Foreground="#B00020" TextWrapping="Wrap" />
        </Grid>

        <WrapPanel Grid.Row="4" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Loc.OpenFolder}" MinHeight="48" Margin="0,0,8,8" Command="{Binding OpenFolderCommand}" />
            <Button Content="{DynamicResource Loc.OpenFile}" MinHeight="48" Margin="0,0,8,8" Command="{Binding OpenFileCommand}" />
            <Button Content="{DynamicResource Loc.Cancel}" MinHeight="48" Margin="0,0,8,8" Command="{Binding CancelCommand}" />
            <Button Content="{DynamicResource Loc.Reject}" MinHeight="48" Margin="0,0,8,8" Command="{Binding RejectCommand}" />
            <Button Content="{DynamicResource Loc.Accept}" MinHeight="48" MinWidth="88" Margin="0,0,0,8" Command="{Binding AcceptCommand}" />
        </WrapPanel>
    </Grid>
    </ScrollViewer>
</Window>
