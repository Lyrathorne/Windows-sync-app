<Window x:Class="DeviceSync.App.IncomingFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Incoming file — DeviceSync"
        Width="560"
        Height="500"
        MinWidth="480"
        MinHeight="440"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Incoming file" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="Review the file before accepting it." Foreground="#555555" Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Device" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="{Binding DeviceName}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="2" Text="File" FontWeight="SemiBold" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FileName}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="4" Text="Size" FontWeight="SemiBold" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FileSize}" />
            <TextBlock Grid.Row="6" Text="MIME type" FontWeight="SemiBold" />
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding MimeType}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="8" Text="Save to" FontWeight="SemiBold" />
            <DockPanel Grid.Row="8" Grid.Column="1">
                <Button DockPanel.Dock="Right" Content="Choose..." Margin="8,0,0,0" Command="{Binding ChooseFolderCommand}" />
                <TextBlock Text="{Binding SaveDirectory}" TextWrapping="Wrap" VerticalAlignment="Center" />
            </DockPanel>

            <ProgressBar Grid.Row="10" Grid.ColumnSpan="2" Height="18" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" />
            <TextBlock Grid.Row="12" Grid.ColumnSpan="2" Text="{Binding ProgressText}" />
            <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding SpeedText}" HorizontalAlignment="Right" />
            <TextBlock Grid.Row="14" Grid.ColumnSpan="2" Text="{Binding Status}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="16" Grid.ColumnSpan="2" Text="{Binding Error}" Foreground="#B00020" TextWrapping="Wrap" />
        </Grid>

        <WrapPanel Grid.Row="4" HorizontalAlignment="Right">
            <Button Content="Open folder" Margin="0,0,8,0" Command="{Binding OpenFolderCommand}" />
            <Button Content="Open file" Margin="0,0,8,0" Command="{Binding OpenFileCommand}" />
            <Button Content="Cancel" Margin="0,0,8,0" Command="{Binding CancelCommand}" />
            <Button Content="Reject" Margin="0,0,8,0" Command="{Binding RejectCommand}" />
            <Button Content="Accept" MinWidth="88" Command="{Binding AcceptCommand}" />
        </WrapPanel>
    </Grid>
</Window>
