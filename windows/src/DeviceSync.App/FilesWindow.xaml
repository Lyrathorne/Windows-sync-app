<Window x:Class="DeviceSync.App.FilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photos and files — DeviceSync"
        Width="1040" Height="720" MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource Ds.Window}"
        AutomationProperties.Name="Photos and files from phone">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="GridListStyle" TargetType="ListBox">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsGridMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DetailListStyle" TargetType="ListBox">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsGridMode}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Photos and files" FontSize="30" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Ds.Brush.OnSurfaceMuted}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding ViewModeLabel}" Command="{Binding ToggleViewCommand}" Margin="8,0,0,0" />
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,16,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="Search phone files"
                     ToolTip="Search by file name" Margin="0,0,8,0" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}" SelectedIndex="{Binding CategoryIndex}"
                      AutomationProperties.Name="File category" Margin="0,0,8,0" />
            <ComboBox Grid.Column="2" ItemsSource="{Binding SortOptions}" SelectedIndex="{Binding SortIndex}"
                      AutomationProperties.Name="File sorting" Margin="0,0,8,0" />
            <Button Grid.Column="3" Content="Search" Command="{Binding RefreshCommand}" />
        </Grid>

        <Grid Grid.Row="2">
            <ListBox ItemsSource="{Binding Items}" SelectionMode="Extended"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     Style="{StaticResource GridListStyle}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <Setter Property="Margin" Value="5" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="210" Height="190" Padding="10"
                                Background="{DynamicResource Ds.Brush.Surface}"
                                CornerRadius="12"
                                Loaded="CatalogItem_Loaded">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource Ds.Brush.SurfaceVariant}" CornerRadius="8">
                                    <Grid>
                                        <TextBlock Text="{Binding Category}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Ds.Brush.OnSurfaceMuted}" />
                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                    </Grid>
                                </Border>
                                <TextBlock Grid.Row="1" Text="{Binding DisplayName}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" Margin="0,8,0,0" />
                                <TextBlock Grid.Row="2" Text="{Binding Detail}" FontSize="11"
                                           Foreground="{DynamicResource Ds.Brush.OnSurfaceMuted}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ListBox ItemsSource="{Binding Items}" SelectionMode="Extended"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     Style="{StaticResource DetailListStyle}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="76" Margin="4" Loaded="CatalogItem_Loaded">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <Border Margin="0,4,10,4" Background="{DynamicResource Ds.Brush.SurfaceVariant}" CornerRadius="7">
                                <Grid>
                                    <TextBlock Text="{Binding Category}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource Ds.Brush.OnSurfaceMuted}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding Category}" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding Error}" Foreground="{DynamicResource Ds.Brush.Error}" TextWrapping="Wrap" />
            </StackPanel>

            <Border Padding="34" CornerRadius="18"
                    Background="{DynamicResource Ds.Brush.Surface}"
                    BorderBrush="{DynamicResource Ds.Brush.Outline}" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="470">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                               Foreground="{DynamicResource Ds.Brush.Primary}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Demo preview" FontSize="22" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,14,0,0" />
                    <TextBlock Text="Connect a phone with media-catalog-v1 support to replace this empty preview with real MediaStore photos and SAF documents."
                               TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource Ds.Brush.OnSurfaceMuted}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{Binding DownloadStatus}" />
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding DownloadProgress, Mode=OneWay}" Height="7" />
            </StackPanel>
            <WrapPanel Grid.Column="1" Margin="12,0,0,0">
                <Button Content="Load more" Command="{Binding LoadMoreCommand}" Margin="0,0,8,0" />
                <Button Content="Open downloaded" Command="{Binding OpenDownloadedCommand}" Margin="0,0,8,0" />
                <Button Content="Cancel" Command="{Binding CancelDownloadCommand}" Margin="0,0,8,0" />
                <Button Content="Download selected…" Command="{Binding DownloadSelectedCommand}" />
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
